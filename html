];

// ── View ──
function showView(n){document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));document.getElementById(n+'-view').classList.add('active');window.scrollTo(0,0)}
function goMain(){showView('main')}
function showStr(){showView('str');buildDates();buildTimes()}
function showAdmin(){showView('adm');renderAdmProds();renderHoursEd();renderOrds();updStats()}
function later(id){setTimeout(()=>{const el=document.getElementById(id);if(el)el.scrollIntoView({behavior:'smooth'})},60)}
window.addEventListener('hashchange',()=>{if(location.hash==='#admin')showAdmin()});
if(location.hash==='#admin')setTimeout(showAdmin,100);

// ── Products ──
const placeholderSvg=(cat)=>`<svg width="56" height="56" viewBox="0 0 56 56" fill="none" opacity=".15"><ellipse cx="28" cy="28" rx="18" ry="5.5" stroke="#1557a0" stroke-width="1.5"/><line x1="28" y1="10" x2="28" y2="46" stroke="#1557a0" stroke-width="1.5"/><ellipse cx="28" cy="28" rx="5.5" ry="18" stroke="#1557a0" stroke-width="1.5"/></svg>`;
function renderProds(f){
  const g=document.getElementById('pg');
  const list=f==='all'?prods.filter(p=>p.live):prods.filter(p=>p.cat===f&&p.live);
  if(!list.length){g.innerHTML='<p style="color:#aab4bf;font-size:13px;padding:32px 0;font-weight:300">暫無商品</p>';return}
  g.innerHTML=list.map(p=>`<div class="pc">
    <div class="pc-img" style="background:${catBg[p.cat]||'#f4f7fb'}">
      ${p.img?`<img src="${p.img}" alt="${p.name}">`:`<div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%">${placeholderSvg(p.cat)}</div>`}
      ${p.badge?`<span class="pc-tag ${p.badge==='new'?'tag-new':p.badge==='sale'?'tag-sale':'tag-hot'}">${p.badge}</span>`:''}
    </div>
    <div class="pc-brand">${p.brand}</div>
    <div class="pc-name">${p.name}</div>
    <div class="pc-foot">
      <div>${p.badge==='sale'?`<span class="pc-old">NT$ ${Math.round(p.price*1.15).toLocaleString()}</span>`:''}<span class="pc-price">NT$ ${p.price.toLocaleString()}</span></div>
      <button class="add-btn" onclick="addCart(${p.id})">+</button>
    </div>
  </div>`).join('');
}
function setFlt(f,btn){curFlt=f;document.querySelectorAll('.flt').forEach(b=>b.classList.remove('on'));if(btn)btn.classList.add('on');else document.querySelector('.flt').classList.add('on');renderProds(f)}

// ── Cart ──
function addCart(id){const p=prods.find(x=>x.id===id);const e=cart.find(x=>x.id===id);if(e)e.qty++;else cart.push({...p,qty:1});updBadge();toast('已加入：'+p.name)}
function rmCart(id){cart=cart.filter(x=>x.id!==id);updBadge();renderCart()}
function updBadge(){document.getElementById('cN').textContent=cart.reduce((s,c)=>s+c.qty,0)}
function renderCart(){
  const el=document.getElementById('cart-list'),ft=document.getElementById('cart-ft');
  if(!cart.length){
    el.innerHTML='<div class="cart-nil"><svg width="38" height="38" viewBox="0 0 38 38" fill="none"><path d="M3 3h5l5 18h16L32 8H10" stroke="#dde2e8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="15" cy="33" r="2.5" stroke="#dde2e8" stroke-width="1.8"/><circle cx="26" cy="33" r="2.5" stroke="#dde2e8" stroke-width="1.8"/></svg><p>購物車目前是空的</p></div>';
    ft.style.display='none';return;
  }
  ft.style.display='block';
  el.innerHTML=cart.map(c=>`<div class="ci"><div class="ci-img" style="background:${catBg[c.cat]||'#f4f7fb'}">${c.img?`<img src="${c.img}">`:`<div style="opacity:.2">${placeholderSvg(c.cat).replace('width="56" height="56"','width="28" height="28"')}</div>`}</div><div class="ci-info"><div class="ci-n">${c.name}</div><div class="ci-b">${c.brand} × ${c.qty}</div><div class="ci-p">NT$ ${(c.price*c.qty).toLocaleString()}</div><button class="ci-rm" onclick="rmCart(${c.id})">移除</button></div></div>`).join('');
  document.getElementById('cart-total').textContent=`NT$ ${cart.reduce((s,c)=>s+(c.price*c.qty),0).toLocaleString()}`;
}
function toggleCart(){renderCart();document.getElementById('cart-bg').classList.toggle('on');document.getElementById('cart-panel').classList.toggle('on')}

// ── Toast ──
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('on');setTimeout(()=>t.classList.remove('on'),2200)}

// ── Stringing ──
function pickStr(el,n,p){document.querySelectorAll('.sp').forEach(x=>x.classList.remove('on'));el.classList.add('on');selStr={name:n,price:p};updSum()}
function updTen(v){document.getElementById('ten-lbl').textContent=v+' lbs';document.getElementById('ten-v').textContent=v}
function updSum(){document.getElementById('bk-s').textContent=`NT$ ${selStr.price}`;document.getElementById('bk-t').textContent=`NT$ ${selStr.price+150}`}
function buildDates(){
  const g=document.getElementById('dg'),days=['日','一','二','三','四','五','六'],today=new Date();let h='',c=0;
  for(let i=1;i<=14&&c<10;i++){const d=new Date(today);d.setDate(today.getDate()+i);if(d.getDay()!==0){h+=`<div class="db" onclick="selD(this)"><span class="d">${d.getDate()}</span><span class="w">${days[d.getDay()]}</span></div>`;c++}}
  g.innerHTML=h;
}
function selD(el){document.querySelectorAll('.db').forEach(b=>b.classList.remove('on'));el.classList.add('on')}
function buildTimes(){
  const ts=['10:00','11:00','12:00','14:00','15:00','16:00','17:00','18:00','19:00'],na=['11:00','15:00'];
  document.getElementById('tg').innerHTML=ts.map(t=>`<div class="tb ${na.includes(t)?'na':''}" onclick="${na.includes(t)?'':''} selT(this,'${t}')">${t}</div>`).join('');
}
function selT(el){if(el.classList.contains('na'))return;document.querySelectorAll('.tb').forEach(b=>b.classList.remove('on'));el.classList.add('on')}
function submitStr(){
  const n=document.getElementById('sn').value.trim(),p=document.getElementById('sp2').value.trim();
  if(!n||!p){toast('請填寫姓名和電話');return}
  if(!document.querySelector('.db.on')){toast('請選擇取件日期');return}
  if(!document.querySelector('.tb.on')){toast('請選擇取件時間');return}
  const ok=document.getElementById('ok-msg');ok.classList.add('on');
  document.getElementById('sn').value='';document.getElementById('sp2').value='';
  document.querySelectorAll('.db').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.tb').forEach(b=>b.classList.remove('on'));
  setTimeout(()=>ok.classList.remove('on'),5000);
}

// ── Hours footer ──
function renderFtHours(){
  const el=document.getElementById('ft-hours');if(!el)return;
  el.innerHTML=hours.map(h=>`<div class="ft-hr-row"><span>${h.d}</span><span>${h.open?`${h.from}–${h.to}`:'公休'}</span></div>`).join('');
}
function renderHoursEd(){
  document.getElementById('he-rows').innerHTML=hours.map((h,i)=>`
    <div class="he-row">
      <span class="he-day">${h.d}</span>
      <div class="sw"><input type="checkbox" id="sw-${i}" ${h.open?'checked':''} onchange="hours[${i}].open=this.checked;renderHoursEd()"><label for="sw-${i}"></label></div>
      <span class="he-status" style="font-size:12px;color:${h.open?'#1557a0':'#aab4bf'}">${h.open?'營業':'公休'}</span>
      <div class="he-times">
        <input type="time" value="${h.from}" onchange="hours[${i}].from=this.value" ${h.open?'':'disabled'} style="${h.open?'':'opacity:.35'}">
        <span class="he-sep">—</span>
        <input type="time" value="${h.to}" onchange="hours[${i}].to=this.value" ${h.open?'':'disabled'} style="${h.open?'':'opacity:.35'}">
      </div>
    </div>`).join('');
}
function saveHours(){renderFtHours();toast('營業時間已更新！')}

// ── Admin Products ──
function handleImg(e){Array.from(e.target.files).forEach(f=>{const r=new FileReader();r.onload=ev=>{imgs.push(ev.target.result);renderPrev()};r.readAsDataURL(f)})}
function renderPrev(){document.getElementById('up-prev').innerHTML=imgs.map((s,i)=>`<div class="up-thumb"><img src="${s}"><button class="up-rm" onclick="imgs.splice(${i},1);renderPrev()">✕</button></div>`).join('')}
function addProd(){
  const n=document.getElementById('ap-n').value.trim(),p=parseInt(document.getElementById('ap-p').value);
  if(!n||!p){toast('請填寫名稱和售價');return}
  prods.unshift({id:nextId++,brand:document.getElementById('ap-b').value.trim()||'其他',name:n,price:p,cat:document.getElementById('ap-c').value,stock:parseInt(document.getElementById('ap-s').value)||0,badge:null,live:document.getElementById('ap-live').checked,img:imgs[0]||null});
  imgs=[];renderPrev();['ap-n','ap-b','ap-p','ap-s','ap-d'].forEach(id=>document.getElementById(id).value='');
  renderAdmProds();renderProds(curFlt);updStats();toast('商品已新增！');
}
function delProd(id){prods=prods.filter(p=>p.id!==id);renderAdmProds();renderProds(curFlt);updStats()}
function togLive(id){const p=prods.find(x=>x.id===id);if(p)p.live=!p.live;renderAdmProds();renderProds(curFlt);updStats()}
function renderAdmProds(){
  document.getElementById('prod-lbl').textContent=`${prods.length} 件`;
  document.getElementById('prod-body').innerHTML=prods.map(p=>`<tr>
    <td><div class="td-prod"><div class="td-img" style="background:${catBg[p.cat]||'#f4f7fb'}">${p.img?`<img src="${p.img}">`:`<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;opacity:.3">${placeholderSvg(p.cat).replace('width="56" height="56"','width="24" height="24"')}</div>`}</div><div><div style="font-size:13px;font-weight:500">${p.name}</div><div style="font-size:11px;color:#aab4bf">${p.brand}</div></div></div></td>
    <td style="font-size:12px;color:#667">${catZh[p.cat]||p.cat}</td>
    <td style="font-size:14px;font-family:'Playfair Display',serif">NT$ ${p.price.toLocaleString()}</td>
    <td style="font-size:13px;color:#667">${p.stock}</td>
    <td><span class="pill ${p.live?'pill-live':'pill-draft'}">${p.live?'上架中':'草稿'}</span></td>
    <td><div class="act-btns"><button class="abt" onclick="togLive(${p.id})">${p.live?'下架':'上架'}</button><button class="abt del" onclick="delProd(${p.id})">刪除</button></div></td>
  </tr>`).join('');
}
function updStats(){document.getElementById('liveN').textContent=prods.filter(p=>p.live).length;document.getElementById('draftN').textContent=prods.filter(p=>!p.live).length}

// ── Orders ──
function renderOrds(){
  const list=ordFlt==='all'?mockOrds:mockOrds.filter(o=>o.status===ordFlt);
  document.getElementById('ord-body').innerHTML=list.map(o=>`<tr>
    <td style="font-size:12px;font-weight:600;color:#1557a0">${o.id}</td>
    <td style="font-size:13px">${o.cust}</td>
    <td style="font-size:12px;color:#667">${o.items}</td>
    <td style="font-size:14px;font-family:'Playfair Display',serif">NT$ ${o.amt.toLocaleString()}</td>
    <td><span class="pc-tag ${stCls[o.status]}" style="position:static">${stZh[o.status]}</span></td>
    <td style="font-size:12px;color:#aab4bf">${o.time}</td>
    <td><button class="abt" onclick="toast('訂單詳情功能開發中')">查看</button></td>
  </tr>`).join('');
}
function fOrd(f,btn){ordFlt=f;document.querySelectorAll('.of').forEach(b=>b.classList.remove('on'));btn.classList.add('on');renderOrds()}

// ── Tabs ──
function switchTab(n,btn){document.querySelectorAll('.at').forEach(b=>b.classList.remove('on'));document.querySelectorAll('.tab-p').forEach(p=>p.classList.remove('on'));btn.classList.add('on');document.getElementById('tab-'+n).classList.add('on');if(n==='hours')renderHoursEd()}

// ── Init ──
renderProds('all');
buildDates();
buildTimes();
renderFtHours();
</script>
