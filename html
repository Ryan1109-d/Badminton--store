<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>噹噹羽球販賣店</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Sans+TC:wght@300;400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', 'Noto Sans TC', sans-serif;
  background: #fff;
  color: #111;
  font-size: 14px;
  -webkit-font-smoothing: antialiased;
}

/* ───── NAV ───── */
nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(255,255,255,0.97);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid #e8edf2;
  height: 56px;
  display: flex; align-items: center;
  padding: 0 40px;
  gap: 32px;
}
.nav-logo {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: #111;
  cursor: pointer;
  white-space: nowrap;
}
.nav-links { display: flex; gap: 0; margin-left: 8px; }
.nav-links button {
  font-size: 13px; font-weight: 400; color: #555;
  padding: 6px 14px; border-radius: 5px;
  border: none; background: none; cursor: pointer;
  font-family: inherit; transition: color .15s, background .15s;
}
.nav-links button:hover { color: #111; background: #f4f7fb; }
.nav-right { margin-left: auto; display: flex; gap: 8px; align-items: center; }
.cart-btn {
  display: flex; align-items: center; gap: 7px;
  font-size: 13px; font-weight: 500;
  background: #1557a0; color: #fff;
  padding: 8px 18px; border-radius: 5px;
  border: none; cursor: pointer; font-family: inherit;
  transition: background .15s;
}
.cart-btn:hover { background: #0e3f7a; }
.cart-n {
  background: rgba(255,255,255,0.25);
  border-radius: 3px; width: 18px; height: 18px;
  font-size: 10px; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}

/* ───── VIEWS ───── */
.view { display: none; }
.view.active { display: block; }

/* ───── HERO ───── */
#hero {
  padding: 72px 40px 64px;
  border-bottom: 1px solid #e8edf2;
  position: relative;
  overflow: hidden;
}
.hero-bg-accent {
  position: absolute; right: -60px; top: -40px;
  width: 420px; height: 420px;
  border-radius: 50%;
  background: radial-gradient(circle, #ddeeff 0%, transparent 70%);
  pointer-events: none;
}
.hero-eyebrow {
  font-size: 11px; font-weight: 600;
  letter-spacing: .14em; text-transform: uppercase;
  color: #1557a0;
  margin-bottom: 20px;
  display: flex; align-items: center; gap: 10px;
}
.hero-eyebrow::after { content: ''; flex: 0 0 32px; height: 1px; background: #1557a0; }
.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(52px, 7vw, 96px);
  font-weight: 700;
  line-height: 1.0;
  letter-spacing: -2px;
  color: #0a0f14;
  max-width: 900px;
}
.hero-title em { font-style: italic; color: #1557a0; }
.hero-sub {
  margin-top: 24px;
  font-size: 15px; font-weight: 300; color: #555;
  max-width: 480px; line-height: 1.8;
}
.hero-cta {
  margin-top: 36px;
  display: flex; gap: 10px; flex-wrap: wrap;
}
.btn-solid {
  background: #111; color: #fff;
  padding: 12px 28px; border-radius: 4px;
  font-size: 13px; font-weight: 500;
  border: none; cursor: pointer; font-family: inherit;
  transition: background .15s; letter-spacing: .02em;
}
.btn-solid:hover { background: #1557a0; }
.btn-outline {
  background: transparent; color: #111;
  padding: 11px 24px; border-radius: 4px;
  font-size: 13px; font-weight: 500;
  border: 1.5px solid #cdd5df; cursor: pointer; font-family: inherit;
  transition: border-color .15s;
}
.btn-outline:hover { border-color: #1557a0; color: #1557a0; }

/* ───── PRODUCT SECTION ───── */
.prod-section { padding: 56px 40px; }
.section-label {
  font-size: 11px; font-weight: 600;
  letter-spacing: .14em; text-transform: uppercase;
  color: #1557a0; margin-bottom: 8px;
}
.section-title {
  font-family: 'Playfair Display', serif;
  font-size: 32px; font-weight: 400; letter-spacing: -.5px;
  color: #0a0f14; margin-bottom: 28px;
}

/* filter */
.filters {
  display: flex; gap: 4px; margin-bottom: 32px;
  border-bottom: 1px solid #e8edf2; padding-bottom: 16px;
}
.flt {
  font-size: 13px; font-weight: 400; color: #777;
  padding: 6px 16px; border-radius: 3px;
  border: none; background: none; cursor: pointer;
  font-family: inherit; transition: all .13s;
}
.flt:hover { color: #111; }
.flt.on { background: #111; color: #fff; font-weight: 500; }

/* product grid */
.pg {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
  gap: 24px 20px;
}
.pc {
  cursor: pointer;
  group: true;
}
.pc-img {
  aspect-ratio: 1;
  background: #f4f7fb;
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; position: relative;
  transition: background .2s;
  margin-bottom: 14px;
}
.pc:hover .pc-img { background: #e8edf5; }
.pc-img img { width: 100%; height: 100%; object-fit: cover; }
.pc-tag {
  position: absolute; top: 10px; left: 10px;
  font-size: 9px; font-weight: 700; letter-spacing: .06em;
  text-transform: uppercase; padding: 3px 8px; border-radius: 2px;
}
.tag-hot { background: #1557a0; color: #fff; }
.tag-new { background: #111; color: #fff; }
.tag-sale { background: #c0392b; color: #fff; }
.pc-brand {
  font-size: 10px; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase;
  color: #aab4bf; margin-bottom: 5px;
}
.pc-name {
  font-size: 14px; font-weight: 400; color: #111;
  line-height: 1.4; margin-bottom: 12px;
}
.pc-foot { display: flex; align-items: center; justify-content: space-between; }
.pc-price {
  font-family: 'Playfair Display', serif;
  font-size: 17px; color: #111;
}
.pc-old { font-size: 11px; color: #aab4bf; text-decoration: line-through; margin-right: 5px; font-family: 'Inter', sans-serif; }
.add-btn {
  width: 32px; height: 32px; border-radius: 4px;
  background: #111; color: #fff;
  border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; line-height: 1; flex-shrink: 0;
  transition: background .13s;
}
.add-btn:hover { background: #1557a0; }

/* ───── DIVIDER ───── */
.rule { height: 1px; background: #e8edf2; margin: 0 40px; }

/* ───── SERVICES ───── */
.svc-section { padding: 56px 40px; }
.svc-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1px;
  background: #e8edf2;
  border: 1px solid #e8edf2;
  border-radius: 8px;
  overflow: hidden;
  margin-top: 28px;
}
.svc {
  background: #fff; padding: 28px;
  cursor: pointer; transition: background .14s;
}
.svc:hover { background: #f8fafc; }
.svc-ico { font-size: 24px; margin-bottom: 14px; }
.svc-name {
  font-family: 'Playfair Display', serif;
  font-size: 17px; font-weight: 400; margin-bottom: 8px;
}
.svc-desc { font-size: 13px; color: #667; line-height: 1.7; font-weight: 300; }
.svc-link { margin-top: 14px; font-size: 12px; font-weight: 600; color: #1557a0; letter-spacing: .04em; }

/* ───── CART PANEL ───── */
#cart-bg {
  position: fixed; inset: 0;
  background: rgba(10,15,20,.4);
  z-index: 200; opacity: 0; pointer-events: none;
  transition: opacity .22s;
}
#cart-bg.on { opacity: 1; pointer-events: all; }
#cart-panel {
  position: fixed; right: 0; top: 0; bottom: 0;
  width: 380px; background: #fff; z-index: 201;
  transform: translateX(100%);
  transition: transform .28s cubic-bezier(.4,0,.2,1);
  display: flex; flex-direction: column;
  border-left: 1px solid #e8edf2;
}
#cart-panel.on { transform: translateX(0); }
.cart-hd {
  padding: 22px 24px; border-bottom: 1px solid #e8edf2;
  display: flex; align-items: center; justify-content: space-between;
}
.cart-hd h2 {
  font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 400;
}
.x { width: 28px; height: 28px; border-radius: 4px; border: 1px solid #e8edf2; background: none; cursor: pointer; font-size: 13px; color: #777; display: flex; align-items: center; justify-content: center; }
.cart-list { flex: 1; overflow-y: auto; padding: 18px 24px; }
.cart-nil { text-align: center; padding: 60px 0; color: #aab4bf; }
.cart-nil p { margin-top: 10px; font-size: 13px; font-weight: 300; }
.ci { display: flex; gap: 12px; padding: 14px 0; border-bottom: 1px solid #e8edf2; }
.ci-img { width: 56px; height: 56px; background: #f4f7fb; border-radius: 6px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.ci-img img { width: 100%; height: 100%; object-fit: cover; }
.ci-info { flex: 1; }
.ci-n { font-size: 13px; font-weight: 500; line-height: 1.4; }
.ci-b { font-size: 11px; color: #aab4bf; margin-top: 2px; }
.ci-p { font-family: 'Playfair Display', serif; font-size: 15px; margin-top: 5px; }
.ci-rm { font-size: 11px; color: #aab4bf; cursor: pointer; border: none; background: none; font-family: inherit; padding: 0; margin-top: 3px; display: block; }
.ci-rm:hover { color: #c0392b; }
.cart-ft { padding: 18px 24px; border-top: 1px solid #e8edf2; }
.cart-tot { display: flex; justify-content: space-between; font-family: 'Playfair Display', serif; font-size: 18px; margin-bottom: 14px; }
.ck-btn { width: 100%; background: #111; color: #fff; padding: 13px; border-radius: 4px; border: none; font-size: 13px; font-weight: 500; cursor: pointer; font-family: inherit; transition: background .14s; letter-spacing: .02em; }
.ck-btn:hover { background: #1557a0; }
.cart-note { font-size: 11px; color: #aab4bf; text-align: center; margin-top: 10px; line-height: 1.6; }

/* ───── STRINGING VIEW ───── */
#str-view { max-width: 1100px; margin: 0 auto; padding: 52px 40px; }
.back-link {
  display: inline-flex; align-items: center; gap: 7px;
  font-size: 12px; font-weight: 500; color: #667;
  cursor: pointer; border: none; background: none;
  font-family: inherit; padding: 0; margin-bottom: 40px;
  letter-spacing: .04em; text-transform: uppercase;
}
.back-link:hover { color: #1557a0; }
.str-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
.str-l h1 { font-family: 'Playfair Display', serif; font-size: 42px; font-weight: 700; letter-spacing: -1.5px; line-height: 1.1; }
.str-l h1 em { font-style: italic; color: #1557a0; }
.str-l p { font-size: 14px; color: #667; margin-top: 16px; line-height: 1.8; font-weight: 300; }
.feat-list { margin-top: 28px; display: flex; flex-direction: column; gap: 9px; }
.feat { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: #555; }
.feat::before { content: '—'; color: #1557a0; font-weight: 600; flex-shrink: 0; }
.str-tbl { margin-top: 36px; }
.str-tbl-hd {
  display: grid; grid-template-columns: 1fr 1fr auto;
  padding: 8px 0 8px;
  font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #aab4bf;
  border-bottom: 2px solid #111;
}
.str-tbl-row {
  display: grid; grid-template-columns: 1fr 1fr auto;
  padding: 13px 0; border-bottom: 1px solid #e8edf2;
  font-size: 13px; align-items: center;
  transition: background .12s;
}
.str-tbl-row:hover { background: #f8fafc; }
.str-nm { font-weight: 500; }
.str-tp { color: #aab4bf; font-weight: 300; }
.str-pr { font-family: 'Playfair Display', serif; font-size: 15px; color: #1557a0; }

/* booking form */
.bk-form { background: #fff; border: 1px solid #e8edf2; border-radius: 8px; padding: 32px; }
.bk-form h3 { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 400; margin-bottom: 26px; }
.fg { margin-bottom: 18px; }
.fl { font-size: 10.5px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: #aab4bf; display: block; margin-bottom: 7px; }
.fi { width: 100%; padding: 10px 13px; border: 1px solid #e8edf2; border-radius: 4px; font-size: 13px; font-family: inherit; color: #111; background: #fff; outline: none; transition: border-color .14s; }
.fi:focus { border-color: #1557a0; }
.sp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 18px; }
.sp { border: 1px solid #e8edf2; border-radius: 5px; padding: 11px 13px; cursor: pointer; transition: all .13s; }
.sp:hover { border-color: #1557a0; }
.sp.on { border-color: #1557a0; background: #f0f6ff; }
.sp-n { font-size: 13px; font-weight: 500; }
.sp-p { font-size: 11px; color: #aab4bf; margin-top: 2px; }
.ten-row { display: flex; align-items: center; gap: 12px; }
.ten-row input[type=range] { flex: 1; accent-color: #1557a0; }
.ten-val { font-family: 'Playfair Display', serif; font-size: 18px; color: #1557a0; min-width: 54px; text-align: right; }
.dg { display: grid; grid-template-columns: repeat(5,1fr); gap: 6px; }
.db { padding: 9px 4px; border: 1px solid #e8edf2; border-radius: 4px; text-align: center; cursor: pointer; font-size: 12px; transition: all .13s; }
.db:hover { border-color: #1557a0; }
.db.on { background: #111; color: #fff; border-color: #111; }
.db .d { font-weight: 600; font-size: 13px; display: block; }
.db .w { color: #aab4bf; font-size: 10px; display: block; margin-top: 1px; }
.db.on .w { color: rgba(255,255,255,.45); }
.tg { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; }
.tb { padding: 9px; border: 1px solid #e8edf2; border-radius: 4px; text-align: center; cursor: pointer; font-size: 12px; font-weight: 500; transition: all .13s; }
.tb:hover { border-color: #1557a0; }
.tb.on { background: #1557a0; color: #fff; border-color: #1557a0; }
.tb.na { color: #dde2e8; cursor: default; text-decoration: line-through; }
.bk-sum { background: #f8fafc; border-radius: 5px; padding: 16px; font-size: 13px; }
.bk-row { display: flex; justify-content: space-between; color: #667; margin-bottom: 7px; }
.bk-tot-row { display: flex; justify-content: space-between; border-top: 1px solid #e8edf2; padding-top: 10px; margin-top: 4px; font-weight: 600; color: #111; font-size: 14px; }
.ok-btn { width: 100%; background: #1557a0; color: #fff; padding: 13px; border-radius: 4px; border: none; font-size: 13px; font-weight: 500; cursor: pointer; font-family: inherit; transition: background .14s; margin-top: 16px; letter-spacing: .02em; }
.ok-btn:hover { background: #0e3f7a; }
.ok-msg { background: #f0f6ff; border: 1px solid #b3d0f0; border-radius: 5px; padding: 13px 16px; display: none; margin-bottom: 18px; align-items: center; gap: 10px; }
.ok-msg.on { display: flex; }
.ok-msg p { font-size: 13px; font-weight: 500; color: #1557a0; }

/* ───── ADMIN VIEW ───── */
#adm-view { background: #f8fafc; min-height: 100vh; }
.adm-top { background: #0a0f14; color: #fff; padding: 0 40px; height: 58px; display: flex; align-items: center; justify-content: space-between; }
.adm-top h1 { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 400; }
.adm-body { padding: 36px 40px; max-width: 1160px; margin: 0 auto; }
.adm-tabs { display: flex; gap: 0; border-bottom: 1px solid #e8edf2; margin-bottom: 32px; }
.at { padding: 11px 22px; font-size: 13px; font-weight: 400; cursor: pointer; border: none; background: none; color: #667; border-bottom: 2px solid transparent; margin-bottom: -1px; font-family: inherit; transition: all .13s; }
.at:hover { color: #111; }
.at.on { color: #1557a0; border-bottom-color: #1557a0; font-weight: 600; }
.tab-p { display: none; }
.tab-p.on { display: block; }
.stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-bottom: 32px; }
.sc { background: #fff; border: 1px solid #e8edf2; border-radius: 6px; padding: 20px; }
.sc .n { font-family: 'Playfair Display', serif; font-size: 30px; color: #1557a0; }
.sc .l { font-size: 11px; color: #aab4bf; margin-top: 4px; letter-spacing: .03em; }
.sc .d { font-size: 11px; color: #1557a0; margin-top: 3px; }
.adm-split { display: grid; grid-template-columns: 400px 1fr; gap: 24px; align-items: start; }
.card { background: #fff; border: 1px solid #e8edf2; border-radius: 6px; }
.card-hd { padding: 18px 22px; border-bottom: 1px solid #e8edf2; font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 400; }
.card-body { padding: 22px; }
.fr { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.up-zone { border: 1.5px dashed #c4d4e8; border-radius: 5px; padding: 26px; text-align: center; cursor: pointer; transition: border-color .14s; position: relative; background: #f8fafc; }
.up-zone:hover { border-color: #1557a0; }
.up-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.up-prev { margin-top: 10px; display: grid; grid-template-columns: repeat(3,1fr); gap: 7px; }
.up-thumb { height: 72px; border-radius: 4px; overflow: hidden; position: relative; }
.up-thumb img { width: 100%; height: 100%; object-fit: cover; }
.up-rm { position: absolute; top: 3px; right: 3px; width: 18px; height: 18px; border-radius: 3px; background: rgba(0,0,0,.5); color: #fff; border: none; cursor: pointer; font-size: 10px; display: flex; align-items: center; justify-content: center; }
.tog { position: relative; width: 36px; height: 20px; flex-shrink: 0; }
.tog input { opacity: 0; width: 0; height: 0; position: absolute; }
.tog label { position: absolute; inset: 0; background: #dde2e8; border-radius: 999px; cursor: pointer; transition: background .18s; }
.tog input:checked+label { background: #1557a0; }
.tog label:after { content: ''; position: absolute; width: 14px; height: 14px; background: #fff; border-radius: 50%; top: 3px; left: 3px; transition: transform .18s; }
.tog input:checked+label:after { transform: translateX(16px); }
.save-btn { background: #1557a0; color: #fff; padding: 10px 22px; border-radius: 4px; border: none; font-size: 13px; font-weight: 500; cursor: pointer; font-family: inherit; transition: background .14s; width: 100%; margin-top: 16px; }
.save-btn:hover { background: #0e3f7a; }
.tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
.tbl th { text-align: left; font-size: 10px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: #aab4bf; padding: 10px 14px; border-bottom: 1px solid #e8edf2; }
.tbl td { padding: 13px 14px; border-bottom: 1px solid #e8edf2; vertical-align: middle; }
.tbl tr:last-child td { border-bottom: none; }
.tbl tbody tr:hover td { background: #f8fafc; }
.td-prod { display: flex; align-items: center; gap: 11px; }
.td-img { width: 40px; height: 40px; border-radius: 5px; background: #f4f7fb; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.td-img img { width: 100%; height: 100%; object-fit: cover; }
.pill { display: inline-block; font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 3px; letter-spacing: .04em; }
.pill-live { background: #e8f1fb; color: #1557a0; }
.pill-draft { background: #f4f7fb; color: #aab4bf; border: 1px solid #e8edf2; }
.act-btns { display: flex; gap: 5px; }
.abt { font-size: 11px; padding: 4px 11px; border-radius: 3px; border: 1px solid #e8edf2; background: none; cursor: pointer; color: #667; font-family: inherit; transition: all .12s; }
.abt:hover { border-color: #1557a0; color: #1557a0; }
.abt.del:hover { border-color: #c0392b; color: #c0392b; }
.he-rows { display: flex; flex-direction: column; gap: 8px; }
.he-row { display: flex; align-items: center; gap: 14px; padding: 11px 16px; background: #fff; border: 1px solid #e8edf2; border-radius: 5px; }
.he-day { width: 48px; font-size: 13px; font-weight: 500; color: #111; }
.sw { position: relative; width: 34px; height: 19px; flex-shrink: 0; }
.sw input { opacity: 0; width: 0; height: 0; position: absolute; }
.sw label { position: absolute; inset: 0; background: #dde2e8; border-radius: 999px; cursor: pointer; transition: background .18s; }
.sw input:checked+label { background: #1557a0; }
.sw label:after { content: ''; position: absolute; width: 13px; height: 13px; background: #fff; border-radius: 50%; top: 3px; left: 3px; transition: transform .18s; }
.sw input:checked+label:after { transform: translateX(15px); }
.he-status { font-size: 12px; width: 32px; }
.he-times { display: flex; align-items: center; gap: 7px; margin-left: auto; }
.he-times input[type=time] { width: 76px; padding: 5px 8px; border: 1px solid #e8edf2; border-radius: 4px; font-size: 12px; font-family: inherit; color: #111; }
.he-times input[type=time]:focus { outline: none; border-color: #1557a0; }
.he-sep { font-size: 12px; color: #aab4bf; }
